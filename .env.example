# ════════════════════════════════════════════════════════════════════
# Drucka env vars — React + Vite frontend / Vercel serverless backend.
# This project is NOT Next.js: there are NO NEXT_PUBLIC_ variables.
# Frontend-public vars use the VITE_ prefix; everything else is a
# backend secret that must only exist in Vercel env (never committed,
# never VITE_-prefixed — VITE_ vars are bundled into the browser!).
# ════════════════════════════════════════════════════════════════════

# ── FRONTEND (PUBLIC — Vite build-time, bundled into the browser) ──
# Only ever put non-secret values behind the VITE_ prefix.
VITE_STAGING=true              # true → amber STAGING banner; unset/false for live
VITE_API_BASE_URL=             # empty = same origin (Vercel hosts frontend+API).
                               # Set https://your-project.vercel.app only when the
                               # frontend is hosted elsewhere (e.g. Hostinger).

# ── BACKEND SECRETS (Vercel → Settings → Environment Variables only) ──

# Qikink (from https://creator.qikink.com/dashboard → API)
QIKINK_CLIENT_ID=your_qikink_client_id
QIKINK_CLIENT_SECRET=your_qikink_client_secret
QIKINK_MODE=sandbox            # sandbox | live  (staging/COD testing = sandbox)
AUTO_SEND_ON_PAID=false        # false while COD testing; true for live auto-send

# Supabase (Project Settings → API — use the SERVICE ROLE key, server-only;
# the anon key is NOT used anywhere in this project)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary (Dashboard → API Keys — signed uploads, no upload preset needed)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Admin access for /api/orders + /api/admin/* — any strong random string
ADMIN_SECRET=your_admin_secret

# CORS: frontend origin allowed to call this API.
# "*" for staging; lock to https://www.drucka.in (or your Hostinger domain) live.
ALLOWED_ORIGIN=https://www.drucka.in

# ── OPTIONAL: Razorpay (only when ENABLE_RAZORPAY goes true) ──
RAZORPAY_KEY_ID=your_razorpay_key_id   # public — sent to the browser by the API
RAZORPAY_KEY_SECRET=your_razorpay_key_secret    # server only
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── STAGING values (Vercel Preview environment / COD testing mode) ──
#   QIKINK_MODE=sandbox · AUTO_SEND_ON_PAID=false · ALLOWED_ORIGIN=* ·
#   VITE_STAGING=true
#   (Frontend flags in src/App.jsx FEATURES: ENABLE_COD_TESTING=true,
#    ENABLE_RAZORPAY=false)

# ── OLD Next.js vars — DELETE from Vercel, no longer used anywhere ──
#   NEXT_PUBLIC_ADMIN_PASSWORD          → replaced by ADMIN_SECRET (server-side)
#   NEXT_PUBLIC_SUPABASE_URL            → replaced by SUPABASE_URL (server-side)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY       → not needed (PostgREST via service role)
#   NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME   → replaced by CLOUDINARY_CLOUD_NAME
#   NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET→ not needed (signed uploads server-side)
