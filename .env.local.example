# DRUCKA — environment variables example
# Copy this file to ".env.local" and fill in your real Cloudinary values.
# (.env.local is git-ignored; never commit real secrets.)
#
# Cloudinary unsigned upload is used for custom design images.
# Setup:
#   1. Create a free account at https://cloudinary.com
#   2. Dashboard -> copy your "Cloud name"
#   3. Settings -> Upload -> Upload presets -> Add upload preset
#        - Signing Mode: Unsigned
#        - (optional) Folder: drucka-designs
#        - Save and copy the preset name
#   4. Paste both values below, then restart `npm run dev`.
#
# These are NEXT_PUBLIC_ because the upload runs in the browser. Unsigned presets
# are made for client-side uploads and do NOT expose your Cloudinary API secret.

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Simple front-end password for the /admin page (temporary, until real auth).
# If unset, the app falls back to "drucka-admin".
NEXT_PUBLIC_ADMIN_PASSWORD=change-this-password
