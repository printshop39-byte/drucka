"use client";

import { Suspense, useMemo, useRef, useState } from "react";
import { useRouter, useSearchParams } from "next/navigation";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import CustomizePreview, { PreviewState, POS_MAP } from "@/components/CustomizePreview";
import { getCustomizableProducts, getProductById } from "@/data/products";
import { useCart } from "@/components/CartContext";

const AI_IDEAS = [
  "<b>Birthday:</b> a photo collage on a mug with the name in gold script.",
  "<b>Anniversary:</b> a framed couple photo with \"Forever & Always\" caption.",
  "<b>Office gift:</b> a minimalist quote T-shirt in your team colors.",
  "<b>Festival:</b> a rangoli-style design on a cushion with a warm greeting.",
  "<b>Baby shower:</b> a soft pastel frame with the baby's name and birth date.",
  "<b>Friendship:</b> a fun caricature mug with an inside-joke caption.",
];

const POS_KEYS = ["tl", "tc", "tr", "ml", "c", "mr", "bl", "bc", "br"];
const POS_LABEL: Record<string, string> = {
  tl: "↖", tc: "↑", tr: "↗", ml: "←", c: "●", mr: "→", bl: "↙", bc: "↓", br: "↘",
};

function StudioInner() {
  const router = useRouter();
  const params = useSearchParams();
  const { addItem } = useCart();
  const fileRef = useRef<HTMLInputElement>(null);

  const products = getCustomizableProducts();
  const initialId = params.get("product") && getProductById(params.get("product")!)
    ? params.get("product")!
    : products[0].id;

  const [productId, setProductId] = useState(initialId);
  const [qty, setQty] = useState(1);
  const [adding, setAdding] = useState(false);
  const [aiIdea, setAiIdea] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);
  const [dragging, setDragging] = useState(false);

  const [state, setState] = useState<PreviewState>({
    uploadedImage: null, text: "", imgScale: 110, textSize: 20, pos: "c",
  });

  const product = useMemo(() => getProductById(productId)!, [productId]);

  const custom = (state.uploadedImage ? 100 : 0) + (state.text.trim() ? 50 : 0);
  const total = (product.price + custom) * qty;

  function handleFile(file: File) {
    if (!file.type.startsWith("image/")) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      setState((s) => ({ ...s, uploadedImage: e.target?.result as string }));
      setFileName(file.name);
    };
    reader.readAsDataURL(file);
  }

  function addToCart() {
    addItem(
      {
        id: product.id,
        name: product.name,
        price: product.price + custom,
        image: product.image,
        fallbackEmoji: product.fallbackEmoji,
        meta: [state.uploadedImage && "Custom image", state.text.trim() && "Custom text"].filter(Boolean).join(" + ") || "Custom design",
      },
      qty
    );
    setAdding(true);
    setTimeout(() => router.push("/cart"), 800);
  }

  return (
    <>
      <Navbar active="customize" />

      <div className="pt-[34px] pb-[10px]">
        <div className="wrap">
          <span className="eyebrow">Design Studio</span>
          <h1 className="text-[clamp(1.9rem,4vw,2.6rem)] mt-3">Create Your Custom Print</h1>
          <p className="text-brand-muted mt-[6px]">Pick a product, upload your photo or add text, then position it live. Your price updates instantly.</p>
        </div>
      </div>

      <div className="wrap">
        <div className="grid [grid-template-columns:1.15fr_1fr] max-[960px]:grid-cols-1 gap-7 py-6 items-start">

          {/* LEFT: PREVIEW */}
          <div className="bg-white/[0.86] border border-brand-border rounded-premium shadow-soft backdrop-blur-[14px] p-[22px] sticky top-[92px] max-[960px]:static transition hover:-translate-y-1 hover:shadow-premium">
            <CustomizePreview product={product} state={state} />

            <div className="flex items-center justify-between mt-4 flex-wrap gap-[10px]">
              <div className="font-bold">{product.name}<small className="block text-brand-muted font-normal text-[0.82rem]">Base price ₹{product.price}</small></div>
              <span className="badge badge-green">Live preview</span>
            </div>

            {/* PRODUCT SWITCHER */}
            <div className="flex gap-[10px] mt-[18px] flex-wrap">
              {products.map((p) => (
                <button
                  key={p.id}
                  onClick={() => setProductId(p.id)}
                  className={`flex-1 min-w-[74px] border rounded-[14px] p-[12px_6px] text-center cursor-pointer transition hover:-translate-y-[3px] hover:border-brand-gold/50 ${productId === p.id ? "bg-brand-primary border-brand-primary" : "bg-white border-brand-border"}`}
                >
                  <span className="text-[1.6rem]">{p.fallbackEmoji}</span>
                  <span className={`block text-[0.78rem] font-bold mt-1 ${productId === p.id ? "text-white" : "text-brand-ink"}`}>{p.name.replace("Premium ", "").replace("Framed ", "").replace("Photo ", "")}</span>
                </button>
              ))}
            </div>
          </div>

          {/* RIGHT: TOOLS */}
          <div className="bg-white border border-brand-border rounded-premium shadow-soft p-6">
            <h3 className="font-heading text-[1.3rem] mb-1">Design Tools</h3>
            <p className="text-brand-muted text-[0.86rem] mb-5">Customize every detail of your print.</p>

            {/* AI CARD */}
            <div className="relative overflow-hidden bg-gradient-to-br from-brand-primary to-brand-dark text-white rounded-[1.1rem] p-5 mb-5">
              <div className="absolute -right-8 -top-10 w-[160px] h-[160px] rounded-full bg-brand-gold/30 blur-[50px]" />
              <div className="relative">
                <span className="badge badge-gold">✨ AI Helper</span>
                <h4 className="text-white text-[1.05rem] mt-2 mb-1">Not sure what to print?</h4>
                <p className="text-white/80 text-[0.85rem]">Tell us the occasion and we&apos;ll suggest a design idea.</p>
                {aiIdea && (
                  <div className="mt-3 bg-white/[0.12] border border-white/[0.18] rounded-[0.8rem] p-[12px_14px] text-[0.86rem]" dangerouslySetInnerHTML={{ __html: aiIdea }} />
                )}
                <button
                  onClick={() => setAiIdea(AI_IDEAS[Math.floor(Math.random() * AI_IDEAS.length)])}
                  className="mt-[14px] w-full bg-brand-gold text-brand-dark rounded-full p-[0.8rem_1rem] font-bold text-[0.9rem] transition hover:-translate-y-[2px] shadow-[0_10px_24px_rgba(216,163,61,0.32)]"
                >
                  {aiIdea ? "Try Another Idea →" : "Get AI Suggestion →"}
                </button>
              </div>
            </div>

            {/* PRODUCT DROPDOWN */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2" htmlFor="productSelect">Select Product</label>
              <select id="productSelect" className="input-premium" value={productId} onChange={(e) => setProductId(e.target.value)}>
                {products.map((p) => (
                  <option key={p.id} value={p.id}>{p.name} — ₹{p.price}</option>
                ))}
              </select>
            </div>

            {/* UPLOAD */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2">Upload Your Image</label>
              <div
                role="button"
                tabIndex={0}
                aria-label="Upload your image — click or drag a file here"
                onClick={() => fileRef.current?.click()}
                onKeyDown={(e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); fileRef.current?.click(); } }}
                onDragOver={(e) => { e.preventDefault(); setDragging(true); }}
                onDragLeave={(e) => { e.preventDefault(); setDragging(false); }}
                onDrop={(e) => { e.preventDefault(); setDragging(false); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); }}
                className={`border-[1.5px] border-dashed rounded-[1.1rem] bg-gradient-to-b from-white to-brand-mint p-[26px_18px] text-center cursor-pointer transition ${dragging ? "border-brand-gold shadow-premium -translate-y-[3px]" : "border-brand-primary/35 hover:border-brand-gold hover:shadow-premium hover:-translate-y-[3px]"}`}
              >
                <div className="text-[2rem]" aria-hidden>⬆️</div>
                <p className="text-brand-muted mt-[6px] text-[0.88rem]"><span className="text-brand-primary font-bold">Click to upload</span> or drag image here</p>
                <p className="text-[0.78rem] text-brand-muted">PNG, JPG up to 20MB</p>
                {fileName && <div className="mt-[10px] text-[0.82rem] text-brand-primary font-bold">✓ {fileName}</div>}
              </div>
              <input ref={fileRef} type="file" accept="image/*" className="hidden" onChange={(e) => e.target.files?.[0] && handleFile(e.target.files[0])} />
            </div>

            {/* TEXT */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2" htmlFor="textInput">Add Text</label>
              <input id="textInput" className="input-premium" type="text" maxLength={40} placeholder="e.g. Happy Birthday Aai ❤️" value={state.text} onChange={(e) => setState((s) => ({ ...s, text: e.target.value }))} />
            </div>

            {/* SIZE */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2">Design Size</label>
              <div className="flex items-center gap-3">
                <input type="range" min={60} max={220} value={state.imgScale} onChange={(e) => setState((s) => ({ ...s, imgScale: +e.target.value }))} className="flex-1 accent-brand-primary" aria-label="Design size" />
                <span className="min-w-[42px] text-right text-[0.82rem] font-bold text-brand-muted tabular-nums">{state.imgScale}%</span>
              </div>
            </div>

            {/* TEXT SIZE */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2">Text Size</label>
              <div className="flex items-center gap-3">
                <input type="range" min={12} max={44} value={state.textSize} onChange={(e) => setState((s) => ({ ...s, textSize: +e.target.value }))} className="flex-1 accent-brand-primary" aria-label="Text size" />
                <span className="min-w-[42px] text-right text-[0.82rem] font-bold text-brand-muted tabular-nums">{state.textSize}px</span>
              </div>
            </div>

            {/* POSITION */}
            <div className="mb-5">
              <label className="block text-[0.82rem] font-bold mb-2">Position</label>
              <div className="grid grid-cols-3 gap-2">
                {POS_KEYS.map((k) => (
                  <button
                    key={k}
                    aria-label={`Position ${k}`}
                    onClick={() => setState((s) => ({ ...s, pos: k }))}
                    className={`rounded-[10px] p-[12px_0] cursor-pointer text-base transition ${state.pos === k ? "bg-brand-primary text-white border border-brand-primary" : "bg-brand-mint text-brand-primary border border-brand-border hover:border-brand-gold/50"}`}
                  >
                    {POS_LABEL[k]}
                  </button>
                ))}
              </div>
            </div>

            {/* PRICE */}
            <div className="bg-brand-mint border border-brand-border rounded-[1.1rem] p-[18px] mb-4">
              <div className="flex items-center justify-between text-[0.9rem] text-brand-muted mb-[6px]"><span>Base price</span><span>₹{product.price}</span></div>
              <div className="flex items-center justify-between text-[0.9rem] text-brand-muted mb-[6px]"><span>Customization</span><span>₹{custom}</span></div>
              <div className="flex items-center justify-between text-[0.9rem] text-brand-muted">
                <span>Quantity</span>
                <span className="inline-flex items-center border border-brand-border rounded-full overflow-hidden bg-white">
                  <button onClick={() => setQty((q) => Math.max(1, q - 1))} className="w-8 h-8 text-brand-primary font-bold text-[1.1rem] hover:bg-brand-mint" aria-label="Decrease quantity">−</button>
                  <span className="min-w-[34px] text-center font-bold text-[0.9rem]" aria-live="polite">{qty}</span>
                  <button onClick={() => setQty((q) => q + 1)} className="w-8 h-8 text-brand-primary font-bold text-[1.1rem] hover:bg-brand-mint" aria-label="Increase quantity">+</button>
                </span>
              </div>
              <div className="flex items-center justify-between mt-[10px] pt-[10px] border-t border-dashed border-brand-border">
                <span className="font-bold text-brand-ink">Total</span>
                <span className="font-heading text-[1.7rem] font-extrabold text-brand-primary">₹{total.toLocaleString("en-IN")}</span>
              </div>
            </div>

            <button onClick={addToCart} disabled={adding} className="btn-primary w-full disabled:opacity-100" style={adding ? { background: "linear-gradient(135deg,#08483B,#06382F)" } : undefined}>
              {adding ? "✓ Added to Cart" : "Add to Cart →"}
            </button>

            <div className="grid grid-cols-2 gap-[10px] mt-4">
              {[["🔒", "Secure Payment"], ["🚚", "Fast Delivery"], ["⭐", "Premium Quality"], ["🎁", "Gift-Ready"]].map(([e, t]) => (
                <div key={t} className="flex items-center gap-2 bg-white border border-brand-border rounded-[0.8rem] p-[10px_12px] text-[0.8rem] font-semibold text-brand-ink"><span className="text-[1.05rem]">{e}</span> {t}</div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <Footer />
    </>
  );
}

export default function CustomizePage() {
  return (
    <Suspense fallback={<div className="wrap py-20 text-brand-muted">Loading studio…</div>}>
      <StudioInner />
    </Suspense>
  );
}
